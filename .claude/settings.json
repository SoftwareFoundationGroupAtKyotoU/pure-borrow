{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "extraKnownMarketplaces": {
    "konn-haskell-claude-tools": {
      "source": {
        "source": "git",
        "url": "https://github.com/konn/haskell-claude-marketplace.git"
      }
    },
    "claude-hoogle": {
      "source": {
        "source": "git",
        "url": "https://github.com/m4dc4p/claude-hoogle.git"
      }
    }
  },
  "enabledPlugins": {
    "haskell-lsp-plugin@konn-haskell-claude-tools": true,
    "haskell-haddock-skill@konn-haskell-claude-tools": true,
    "haskell-skill@konn-haskell-claude-tools": true,
    "hoogle@claude-hoogle": true,
    "haskell-format-skill@konn-haskell-claude-tools": false,
    "haskell-cabal-gild-skill@konn-haskell-claude-tools": false
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^Edit$|^MultiEdit$|^Write$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/hooks/haskell-format-post-tool-use.sh\"",
            "timeout": 60,
            "statusMessage": "Formatting Haskell source"
          },
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.agents/hooks/cabal-gild-post-tool-use.sh\"",
            "timeout": 60,
            "statusMessage": "Formatting cabal files"
          }
        ]
      }
    ]
  }
}
